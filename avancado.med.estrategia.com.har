3\",\"name\":\"Privado\"},\"f99244db-58aa-4669-bb7e-4216d75b733d\":{\"id\":\"af7e85c2-2c30-4a9a-ba79-8caf9d22e744\",\"name\":\"Acesso Direto (R1)\"}},\"number\":1,\"complement\":\"\",\"remuneration\":333043,\"open_spaces\":2,\"candidates_number\":0,\"accepted_candidates_number\":0,\"answers_type\":\"MULTIPLE_CHOICE\",\"active\":true,\"degree_proof\":false,\"questions_number\":50,\"created_at\":\"2020-12-04T13:23:29Z\",\"badges\":[{\"type\":\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\",\"text\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},{\"type\":\"YEAR\",\"text\":\"2021\"},{\"type\":\"4383bd62-e829-491e-8bb5-b40bd649817f\",\"text\":\"Residência (Acesso Direto)\"}]},{\"id\":\"4000002128\",\"scholarity\":\"placeholder\",\"year\":2021,\"catalogs\":{\"4383bd62-e829-491e-8bb5-b40bd649817f\":{\"id\":\"42bcdb35-c6b9-4ff2-bac0-2d2fa575f042\",\"name\":\"Residência (Acesso Direto)\"},\"5d401e50-47cf-4d06-9a2f-19997cd0f258\":{\"id\":\"e7b1a3be-f837-4ed3-868d-18768d33b4a3\",\"name\":\"Instituto Brasileiro de Gestão e Pesquisa (IBGP)\"},\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\":{\"id\":\"260b7239-0661-48ec-80cb-161a373e4367\",\"name\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},\"75851bb5-e834-49af-affe-50e954c40801\":{\"id\":\"dcb47678-bdba-4669-aa0e-01f71e32541b\",\"name\":\"Medicina da Família e Comunidade\"},\"7930032c-3d1b-4a19-a8c8-12bb8137e59a\":{\"id\":\"b9d13d45-c27d-4634-985c-fe9924095039\",\"name\":\"2 anos\"},\"8ff170f3-13a5-4421-8474-4e39649c523f\":{\"id\":\"c0fb2a79-d5f3-4686-8eb4-078b329da379\",\"name\":\"Não se aplica\"},\"9f5ce998-c2c4-47ed-81d3-a9042f54cc33\":{\"id\":\"b35c6fce-73ec-4b54-aae8-ad664a219e03\",\"name\":\"Privado\"},\"f99244db-58aa-4669-bb7e-4216d75b733d\":{\"id\":\"af7e85c2-2c30-4a9a-ba79-8caf9d22e744\",\"name\":\"Acesso Direto (R1)\"}},\"number\":1,\"complement\":\"\",\"remuneration\":333043,\"open_spaces\":3,\"candidates_number\":0,\"accepted_candidates_number\":0,\"answers_type\":\"MULTIPLE_CHOICE\",\"active\":true,\"degree_proof\":false,\"questions_number\":50,\"created_at\":\"2020-12-04T13:23:57Z\",\"badges\":[{\"type\":\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\",\"text\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},{\"type\":\"YEAR\",\"text\":\"2021\"},{\"type\":\"4383bd62-e829-491e-8bb5-b40bd649817f\",\"text\":\"Residência (Acesso Direto)\"}]}],\"topics\":[{\"id\":\"15195453-a3fb-426e-864b-315e8c209087\",\"name\":\"Sistema Único de Saúde (SUS)\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":true,\"path\":\"Medicina Preventiva[$$]Sistema Único de Saúde (SUS)\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"d92f7c3a-d478-46e5-b929-a189738b6b1a\",\"15195453-a3fb-426e-864b-315e8c209087\"],\"has_children\":false,\"nodes\":null},{\"id\":\"d6f8f1e9-20dd-4819-8f2a-44b066c178bb\",\"name\":\"Lei nº 8.080/1990\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":false,\"path\":\"Medicina Preventiva[$$]Sistema Único de Saúde (SUS)[$$]Principais marcos legais do SUS[$$]Leis orgânicas da saúde[$$]Lei nº 8.080/1990\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"d92f7c3a-d478-46e5-b929-a189738b6b1a\",\"15195453-a3fb-426e-864b-315e8c209087\",\"f372192a-c62d-4df6-a7e8-ca9a6e4e0152\",\"13458984-8ebe-4682-aaf8-23fd8ef1abdb\",\"d6f8f1e9-20dd-4819-8f2a-44b066c178bb\"],\"has_children\":false,\"nodes\":null}],\"alternatives\":[{\"id\":\"ae8b2218-3ec3-4c57-a42a-69b7ba5f98cb\",\"position\":\"0\",\"body\":\"A iniciativa privada poderá participar do Sistema Único de Saúde (SUS), em caráter complementar.\",\"body_json\":null,\"sanitized_body\":\"A iniciativa privada poderá participar do Sistema Único de Saúde (SUS), em caráter complementar.\",\"correct\":false,\"created_at\":\"2020-12-04T15:31:37Z\",\"updated_at\":\"2026-03-13T20:46:48Z\",\"topics\":[],\"solution\":{\"_key\":\"940e1cc0-b990-4421-8f18-6154a6f6b9f0\",\"complete\":\"Correto, segundo o art. 199 da CF 1988.\\u003cdiv\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv\\u003eArt. 199. A assistência à saúde é livre à iniciativa privada.\\u003c/div\\u003e\\u003cdiv\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv\\u003e§ 1º As instituições privadas poderão participar de forma complementar do sistema único de saúde, segundo diretrizes deste, mediante contrato de direito público ou convênio, tendo preferência as entidades filantrópicas e as sem fins lucrativos.\\u003c/div\\u003e\",\"complete_json\":null,\"sanitized_complete\":\"Correto, segundo o art. 199 da CF 1988.Art. 199. A assistência à saúde é livre à iniciativa privada.§ 1º As instituições privadas poderão participar de forma complementar do sistema único de saúde, segundo diretrizes deste, mediante contrato de direito público ou convênio, tendo preferência as entidades filantrópicas e as sem fins lucrativos.\",\"complete_attachments\":[{\"type\":\"AUDIO\"}],\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":[{\"type\":\"AUDIO\"}],\"author_id\":\"f54a7342-4120-4f2c-acd2-d8f7bd64ed2f\",\"author_profile\":null,\"created_at\":\"2022-01-26T21:39:31Z\",\"updated_at\":\"2022-01-26T21:43:51Z\"},\"answer_percentage\":5,\"answers\":17},{\"id\":\"3b3c697d-c6d0-4b56-b638-927a022c957e\",\"position\":\"1\",\"body\":\"São objetivos do SUS: a identificação e divulgação de fatores condicionantes e determinantes da saúde; formulação de política de saúde e; assistência às pessoas.\",\"body_json\":null,\"sanitized_body\":\"São objetivos do SUS: a identificação e divulgação de fatores condicionantes e determinantes da saúde; formulação de política de saúde e; assistência às pessoas.\",\"correct\":false,\"created_at\":\"2020-12-04T15:31:37Z\",\"updated_at\":\"2026-03-20T16:11:55Z\",\"topics\":[],\"solution\":{\"_key\":\"99815559-99b6-4411-a19c-12f46fd28c3b\",\"complete\":\"Correto. Conforme consta no Art. 5º da Lei 8.080/1990:\\u003cdiv\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv\\u003eSão objetivos do Sistema Único de Saúde SUS:\\u003cdiv\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv\\u003eI - a identificação e divulgação dos fatores condicionantes e determinantes da saúde;\\u003c/div\\u003e\\u003c/div\\u003e\\u003cdiv\\u003eIl - a formulação de política de saúde destinada a promover, nos campos econômico e social, a observância do disposto no § 1º do art. 2º desta lei;\\u003c/div\\u003e\\u003cdiv\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv\\u003eIII - a assistência às pessoas por intermédio de ações de promoção, proteção e recuperação da saúde, com a realização integrada das ações assistenciais e das atividades preventivas.\\u003c/div\\u003e\",\"complete_json\":null,\"sanitized_complete\":\"Correto. Conforme consta no Art. 5º da Lei 8.080/1990:São objetivos do Sistema Único de Saúde SUS:I - a identificação e divulgação dos fatores condicionantes e determinantes da saúde;Il - a formulação de política de saúde destinada a promover, nos campos econômico e social, a observância do disposto no § 1º do art. 2º desta lei;III - a assistência às pessoas por intermédio de ações de promoção, proteção e recuperação da saúde, com a realização integrada das ações assistenciais e das atividades preventivas.\",\"complete_attachments\":[{\"type\":\"AUDIO\"}],\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":[{\"type\":\"AUDIO\"}],\"author_id\":\"f54a7342-4120-4f2c-acd2-d8f7bd64ed2f\",\"author_profile\":null,\"created_at\":\"2022-01-26T21:39:31Z\",\"updated_at\":\"2022-01-26T21:43:51Z\"},\"answer_percentage\":3,\"answers\":10},{\"id\":\"a2b473e3-e169-4897-944f-f9c9160376b8\",\"position\":\"2\",\"body\":\"As ações e serviços de saúde, executados pelo SUS serão organizados de forma regionalizada e hierarquizada em níveis de complexidade crescente.\",\"body_json\":null,\"sanitized_body\":\"As ações e serviços de saúde, executados pelo SUS serão organizados de forma regionalizada e hierarquizada em níveis de complexidade crescente.\",\"correct\":false,\"created_at\":\"2020-12-04T15:31:37Z\",\"updated_at\":\"2026-01-26T20:28:59Z\",\"topics\":[],\"solution\":{\"_key\":\"cf7ef203-b5fc-4503-9619-96b5b6f50582\",\"complete\":\"Correto, visto a regionalização e hierarquização são princípios organizativos do SUS. Observe novamente a Lei 8.080/90:\\u003cdiv\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv\\u003eArt. 8º As ações e serviços de saúde, executados pelo Sistema Único de Saúde (SUS), seja diretamente ou mediante participação complementar da iniciativa privada, serão organizados de forma regionalizada e hierarquizada em níveis de complexidade crescente.\\u003c/div\\u003e\",\"complete_json\":null,\"sanitized_complete\":\"Correto, visto a regionalização e hierarquização são princípios organizativos do SUS. Observe novamente a Lei 8.080/90:Art. 8º As ações e serviços de saúde, executados pelo Sistema Único de Saúde (SUS), seja diretamente ou mediante participação complementar da iniciativa privada, serão organizados de forma regionalizada e hierarquizada em níveis de complexidade crescente.\",\"complete_attachments\":[{\"type\":\"AUDIO\"}],\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":[{\"type\":\"AUDIO\"}],\"author_id\":\"f54a7342-4120-4f2c-acd2-d8f7bd64ed2f\",\"author_profile\":null,\"created_at\":\"2022-01-26T21:39:31Z\",\"updated_at\":\"2022-01-26T21:43:51Z\"},\"answer_percentage\":7,\"answers\":24},{\"id\":\"18c9ef38-f910-4298-ad30-58b098bc2ba8\",\"position\":\"3\",\"body\":\"A descentralização político-administrativa prevista pelo SUS enfatiza a descentralização dos serviços para os estados.\",\"body_json\":null,\"sanitized_body\":\"A descentralização político-administrativa prevista pelo SUS enfatiza a descentralização dos serviços para os estados.\",\"correct\":true,\"created_at\":\"2020-12-04T15:31:37Z\",\"updated_at\":\"2026-04-02T13:49:01Z\",\"topics\":[],\"solution\":{\"_key\":\"970ce0ca-ad9d-422e-b9a4-a869ecf581c5\",\"complete\":\"Incorreto. A ênfase é para os MUNICÍPIOS!\",\"complete_json\":null,\"sanitized_complete\":\"Incorreto. A ênfase é para os MUNICÍPIOS!\",\"complete_attachments\":[{\"type\":\"AUDIO\"}],\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":[{\"type\":\"AUDIO\"}],\"author_id\":\"f54a7342-4120-4f2c-acd2-d8f7bd64ed2f\",\"author_profile\":null,\"created_at\":\"2022-01-26T21:39:31Z\",\"updated_at\":\"2022-01-26T21:43:51Z\"},\"answer_percentage\":86,\"answers\":303}],\"answer_type\":\"MULTIPLE_CHOICE\",\"statement\":\"A Lei nº 8.080, de 19 de setembro de 1990, dispõe sobre as condições para a promoção, proteção e recuperação da saúde, a organização e o funcionamento dos serviços correspondentes e dá outras providências.\\u003cdiv\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv\\u003eDe acordo com essa lei, assinale a alternativa\\u003c/div\\u003e\\u003cdiv\\u003e\\u003cb\\u003e\\u003cbr\\u003e\\u003c/b\\u003e\\u003c/div\\u003e\\u003cdiv\\u003e\\u003cb\\u003eINCORRETA:\\u003c/b\\u003e\\u003c/div\\u003e\",\"statement_text\":\"A Lei nº 8.080, de 19 de setembro de 1990, dispõe sobre as condições para a promoção, proteção e recuperação da saúde, a organização e o funcionamento dos serviços correspondentes e dá outras providências.De acordo com essa lei, assinale a alternativaINCORRETA:\",\"labels\":[\"FINAL_ANSWER_SHEET\"],\"difficulty_level\":\"MEDIUM\",\"created_at\":\"2020-12-04T15:31:37Z\",\"solution\":{\"_key\":\"74c2e18b-82a0-48c3-a4d7-bb00c4276a8d\",\"complete\":\"Estrategista, estamos procurando a INCORRETA!\",\"complete_json\":null,\"sanitized_complete\":\"Estrategista, estamos procurando a INCORRETA!\",\"complete_attachments\":[{\"type\":\"AUDIO\"}],\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":[{\"type\":\"AUDIO\"}],\"author_id\":\"f54a7342-4120-4f2c-acd2-d8f7bd64ed2f\",\"author_profile\":{\"id\":\"f54a7342-4120-4f2c-acd2-d8f7bd64ed2f\",\"full_name\":\"Thales Thaumaturgo\",\"avatar_url\":\"https://static.accounts.estrategia.com/4527e73fd3defb6d1a7f1ff96eab212b\",\"about_me\":\"Graduação em Medicina na Uniplac, em Lages - SC. Residência Médica em Psiquiatria no Instituto de Psiquiatria de Santa Catarina (IPq - SC). Concursado como Médico Perito na Secretaria de Estado da Administração de Santa Catarina (SEA - SC), sendo atualmente Supervisor Médico da Perícia Oficial do Estado. Professor de Psiquiatria no Estratégia Concursos.\",\"anonymized_areas\":[]},\"created_at\":\"2022-01-26T21:39:31Z\",\"updated_at\":\"2022-01-26T21:43:52Z\"},\"status\":{\"value\":\"APPROVED\"},\"has_video_solution\":false,\"solution_video_url\":\"\",\"unlisted\":false,\"slug\":\"Lei-no-8-080-19419cf0e565\",\"public\":true,\"solution_video_resolutions\":null,\"has_support_text\":false,\"body_support_html\":\"\",\"body_support_json\":null}],\"pagination\":{\"page\":1,\"per_page\":1,\"total\":7},\"token_pagination\":{\"next_page_token\":\"WzIwMjEsIjQwMDAxMjk5NzIiXQ\"}}\n"
