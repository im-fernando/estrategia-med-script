:true,\"degree_proof\":false,\"questions_number\":50,\"created_at\":\"2020-12-04T13:23:57Z\",\"badges\":[{\"type\":\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\",\"text\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},{\"type\":\"YEAR\",\"text\":\"2021\"},{\"type\":\"4383bd62-e829-491e-8bb5-b40bd649817f\",\"text\":\"Residência (Acesso Direto)\"}]}],\"topics\":[{\"id\":\"f1cc3a50-dab4-4287-89a8-f5be31f5e09e\",\"name\":\"Etiologia e transmissão\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":true,\"path\":\"Obstetrícia[$$]Medicina fetal[$$]Infecções congênitas [$$]Citomegalovirus na gestação (CMV)[$$]Etiologia e transmissão\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"c415e40e-bb13-4e11-bd83-d047c806ed3e\",\"50726dbc-912d-4029-a607-30739a555d62\",\"32d4c78c-122b-4218-be35-e87969f348bc\",\"6de776f9-782e-45a3-885a-7813fbaf2460\",\"f1cc3a50-dab4-4287-89a8-f5be31f5e09e\"],\"has_children\":false,\"nodes\":null},{\"id\":\"28cb5c95-faeb-4af5-a91e-a274d39ef496\",\"name\":\"Manifestações clínicas e congênitas\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":false,\"path\":\"Obstetrícia[$$]Medicina fetal[$$]Infecções congênitas [$$]Citomegalovirus na gestação (CMV)[$$]Manifestações clínicas e congênitas\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"c415e40e-bb13-4e11-bd83-d047c806ed3e\",\"50726dbc-912d-4029-a607-30739a555d62\",\"32d4c78c-122b-4218-be35-e87969f348bc\",\"6de776f9-782e-45a3-885a-7813fbaf2460\",\"28cb5c95-faeb-4af5-a91e-a274d39ef496\"],\"has_children\":false,\"nodes\":null},{\"id\":\"7bdde38f-303d-49eb-baa8-91d4c0bca024\",\"name\":\"Manifestações congênitas\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":false,\"path\":\"Obstetrícia[$$]Medicina fetal[$$]Infecções congênitas [$$]Citomegalovirus na gestação (CMV)[$$]Manifestações clínicas e congênitas[$$]Manifestações congênitas\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"c415e40e-bb13-4e11-bd83-d047c806ed3e\",\"50726dbc-912d-4029-a607-30739a555d62\",\"32d4c78c-122b-4218-be35-e87969f348bc\",\"6de776f9-782e-45a3-885a-7813fbaf2460\",\"28cb5c95-faeb-4af5-a91e-a274d39ef496\",\"7bdde38f-303d-49eb-baa8-91d4c0bca024\"],\"has_children\":false,\"nodes\":null}],\"alternatives\":[{\"id\":\"98e64165-4faf-42b9-906a-4cb4e628b6bb\",\"position\":\"0\",\"body\":\"O CMV é um herpes vírus de DNA ubíquo. Tal como acontece com outros herpes vírus, torna-se latente após uma infecção primária, mas pode ser reativado com nova disseminação viral.\",\"body_json\":null,\"sanitized_body\":\"O CMV é um herpes vírus de DNA ubíquo. Tal como acontece com outros herpes vírus, torna-se latente após uma infecção primária, mas pode ser reativado com nova disseminação viral.\",\"correct\":false,\"created_at\":\"2020-12-04T14:15:42Z\",\"updated_at\":\"2025-11-09T02:10:42Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":11,\"answers\":10},{\"id\":\"b07636f4-5915-4fb0-b00b-5a5834106d43\",\"position\":\"1\",\"body\":\"O CMV é a infecção viral congênita mais comum, com prevalência de nascimento de 0,48% a 1,30% nas últimas décadas, sendo que a maioria dos recém-nascidos (RN) com essa infecção, é assintomática.\",\"body_json\":null,\"sanitized_body\":\"O CMV é a infecção viral congênita mais comum, com prevalência de nascimento de 0,48% a 1,30% nas últimas décadas, sendo que a maioria dos recém-nascidos (RN) com essa infecção, é assintomática.\",\"correct\":false,\"created_at\":\"2020-12-04T14:15:42Z\",\"updated_at\":\"2025-10-28T11:46:04Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":26,\"answers\":24},{\"id\":\"89276c2b-85f3-4a28-b71f-bed00a1762a2\",\"position\":\"2\",\"body\":\"As mulheres grávidas imunocompetentes com infecção por CMV devem receber cuidados de suporte para alívio sintomático, conforme necessário sendo que, o uso de medicamentos antivirais é raramente indicado e os medicamentos disponíveis como o ganciclovir, foscarnet e\\to cidofovir não demonstraram diminuir a transmissão perinatal e ainda, as informações sobre os riscos fetais são limitadas.\",\"body_json\":null,\"sanitized_body\":\"As mulheres grávidas imunocompetentes com infecção por CMV devem receber cuidados de suporte para alívio sintomático, conforme necessário sendo que, o uso de medicamentos antivirais é raramente indicado e os medicamentos disponíveis como o ganciclovir, foscarnet e\\to cidofovir não demonstraram diminuir a transmissão perinatal e ainda, as informações sobre os riscos fetais são limitadas.\",\"correct\":false,\"created_at\":\"2020-12-04T14:15:42Z\",\"updated_at\":\"2026-03-07T05:19:17Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":30,\"answers\":27},{\"id\":\"2d511150-eaa4-4db8-adca-2d66c2d4bc7c\",\"position\":\"3\",\"body\":\"Os achados clínicos em RN sintomáticos incluem, pequeno para a idade gestacional, microcefalia, ventriculomegalia, coriorretinite, icterícia, hepatoesplenomegalia, trombocitopenia e petéquias, e a taxa de mortalidade entre os RN sintomáticos é de aproximadamente 40%.\",\"body_json\":null,\"sanitized_body\":\"Os achados clínicos em RN sintomáticos incluem, pequeno para a idade gestacional, microcefalia, ventriculomegalia, coriorretinite, icterícia, hepatoesplenomegalia, trombocitopenia e petéquias, e a taxa de mortalidade entre os RN sintomáticos é de aproximadamente 40%.\",\"correct\":true,\"created_at\":\"2020-12-04T14:15:42Z\",\"updated_at\":\"2026-02-15T17:34:51Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":33,\"answers\":30}],\"answer_type\":\"MULTIPLE_CHOICE\",\"statement\":\"Em relação às infecções por Citomegalovírus (CMV) durante a gravidez, assinale a alternativa \\u003cb\\u003eINCORRETA:\\u003c/b\\u003e\",\"statement_text\":\"Em relação às infecções por Citomegalovírus (CMV) durante a gravidez, assinale a alternativa INCORRETA:\",\"labels\":[\"FINAL_ANSWER_SHEET\"],\"created_at\":\"2020-12-04T14:15:42Z\",\"forum_id\":\"8c3ed65a-e8da-4b65-932d-6ceae82194ea\",\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"status\":{\"value\":\"CREATED\"},\"has_video_solution\":false,\"solution_video_url\":\"\",\"unlisted\":false,\"slug\":\"as-infeccoes-por1417ac0275\",\"public\":true,\"solution_video_resolutions\":null,\"has_support_text\":false,\"body_support_html\":\"\",\"body_support_json\":null}],\"pagination\":{\"page\":1,\"per_page\":1,\"total\":4},\"token_pagination\":{\"next_page_token\":\"WzIwMjEsIjQwMDAxMjk5NDEiXQ\"}}\n"
