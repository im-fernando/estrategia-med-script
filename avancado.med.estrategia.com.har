            "text": "{\"data\":[{\"id\":\"4000129972\",\"exams\":[{\"id\":\"4000002124\",\"scholarity\":\"placeholder\",\"year\":2021,\"catalogs\":{\"4383bd62-e829-491e-8bb5-b40bd649817f\":{\"id\":\"42bcdb35-c6b9-4ff2-bac0-2d2fa575f042\",\"name\":\"Residência (Acesso Direto)\"},\"5d401e50-47cf-4d06-9a2f-19997cd0f258\":{\"id\":\"e7b1a3be-f837-4ed3-868d-18768d33b4a3\",\"name\":\"Instituto Brasileiro de Gestão e Pesquisa (IBGP)\"},\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\":{\"id\":\"260b7239-0661-48ec-80cb-161a373e4367\",\"name\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},\"75851bb5-e834-49af-affe-50e954c40801\":{\"id\":\"9b34a94d-754d-4510-8bad-60f649fa825b\",\"name\":\"Clínica Médica\"},\"7930032c-3d1b-4a19-a8c8-12bb8137e59a\":{\"id\":\"b9d13d45-c27d-4634-985c-fe9924095039\",\"name\":\"2 anos\"},\"8ff170f3-13a5-4421-8474-4e39649c523f\":{\"id\":\"c0fb2a79-d5f3-4686-8eb4-078b329da379\",\"name\":\"Não se aplica\"},\"9f5ce998-c2c4-47ed-81d3-a9042f54cc33\":{\"id\":\"b35c6fce-73ec-4b54-aae8-ad664a219e03\",\"name\":\"Privado\"},\"f99244db-58aa-4669-bb7e-4216d75b733d\":{\"id\":\"af7e85c2-2c30-4a9a-ba79-8caf9d22e744\",\"name\":\"Acesso Direto (R1)\"}},\"number\":1,\"complement\":\"\",\"remuneration\":333043,\"open_spaces\":8,\"candidates_number\":0,\"accepted_candidates_number\":0,\"answers_type\":\"MULTIPLE_CHOICE\",\"active\":true,\"degree_proof\":false,\"questions_number\":50,\"created_at\":\"2020-12-04T13:21:55Z\",\"badges\":[{\"type\":\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\",\"text\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},{\"type\":\"YEAR\",\"text\":\"2021\"},{\"type\":\"4383bd62-e829-491e-8bb5-b40bd649817f\",\"text\":\"Residência (Acesso Direto)\"}]},{\"id\":\"4000002125\",\"scholarity\":\"placeholder\",\"year\":2021,\"catalogs\":{\"4383bd62-e829-491e-8bb5-b40bd649817f\":{\"id\":\"42bcdb35-c6b9-4ff2-bac0-2d2fa575f042\",\"name\":\"Residência (Acesso Direto)\"},\"5d401e50-47cf-4d06-9a2f-19997cd0f258\":{\"id\":\"e7b1a3be-f837-4ed