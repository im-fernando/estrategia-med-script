3-868d-18768d33b4a3\",\"name\":\"Instituto Brasileiro de Gestão e Pesquisa (IBGP)\"},\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\":{\"id\":\"260b7239-0661-48ec-80cb-161a373e4367\",\"name\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},\"75851bb5-e834-49af-affe-50e954c40801\":{\"id\":\"dfa90599-1ee1-4de3-8605-a75ecd3799bd\",\"name\":\"Cirurgia Básica\"},\"7930032c-3d1b-4a19-a8c8-12bb8137e59a\":{\"id\":\"b9d13d45-c27d-4634-985c-fe9924095039\",\"name\":\"2 anos\"},\"8ff170f3-13a5-4421-8474-4e39649c523f\":{\"id\":\"c0fb2a79-d5f3-4686-8eb4-078b329da379\",\"name\":\"Não se aplica\"},\"9f5ce998-c2c4-47ed-81d3-a9042f54cc33\":{\"id\":\"b35c6fce-73ec-4b54-aae8-ad664a219e03\",\"name\":\"Privado\"},\"f99244db-58aa-4669-bb7e-4216d75b733d\":{\"id\":\"af7e85c2-2c30-4a9a-ba79-8caf9d22e744\",\"name\":\"Acesso Direto (R1)\"}},\"number\":1,\"complement\":\"\",\"remuneration\":333043,\"open_spaces\":2,\"candidates_number\":0,\"accepted_candidates_number\":0,\"answers_type\":\"MULTIPLE_CHOICE\",\"active\":true,\"degree_proof\":false,\"questions_number\":50,\"created_at\":\"2020-12-04T13:22:36Z\",\"badges\":[{\"type\":\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\",\"text\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},{\"type\":\"YEAR\",\"text\":\"2021\"},{\"type\":\"4383bd62-e829-491e-8bb5-b40bd649817f\",\"text\":\"Residência (Acesso Direto)\"}]},{\"id\":\"4000002126\",\"scholarity\":\"placeholder\",\"year\":2021,\"catalogs\":{\"4383bd62-e829-491e-8bb5-b40bd649817f\":{\"id\":\"42bcdb35-c6b9-4ff2-bac0-2d2fa575f042\",\"name\":\"Residência (Acesso Direto)\"},\"5d401e50-47cf-4d06-9a2f-19997cd0f258\":{\"id\":\"e7b1a3be-f837-4ed3-868d-18768d33b4a3\",\"name\":\"Instituto Brasileiro de Gestão e Pesquisa (IBGP)\"},\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\":{\"id\":\"260b7239-0661-48ec-80cb-161a373e4367\",\"name\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},\"75851bb5-e834-49af-affe-50e954c40801\":{\"id\":\"046f0505-90c9-4862-b318-388c0d1e8026\",\"name\":\"Anestesiologia\"},\"7930032c-3d1b-4a19-a8c8-12bb8137e59a\":{\"id\":\"27dbfbf8-939d-4abc-b3d8-ea268d974c45\",\"name\":\"3 anos\"},\"8ff170f3-13a5-4421-8474-4e39649c523f\":{\"id\":\"c0fb2a79-d5f3-4686-8eb4-078b329da379\",\"name\":\"Não se aplica\"},\"9f5ce998-c2c4-47ed-81d3-a9042f54cc33\":{\"id\":\"b35c6fce-73ec-4b54-aae8-ad664a219e03\",\"name\":\"Privado\"},\"f99244db-58aa-4669-bb7e-4216d75b733d\":{\"id\":\"af7e85c2-2c30-4a9a-ba79-8caf9d22e744\",\"name\":\"Acesso Direto (R1)\"}},\"number\":1,\"complement\":\"\",\"remuneration\":333043,\"open_spaces\":2,\"candidates_number\":0,\"accepted_candidates_number\":0,\"answers_type\":\"MULTIPLE_CHOICE\",\"active\":true,\"degree_proof\":false,\"questions_number\":50,\"created_at\":\"2020-12-04T13:23:02Z\",\"badges\":[{\"type\":\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\",\"text\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},{\"type\":\"YEAR\",\"text\":\"2021\"},{\"type\":\"4383bd62-e829-491e-8bb5-b40bd649817f\",\"text\":\"Residência (Acesso Direto)\"}]},{\"id\":\"4000002127\",\"scholarity\":\"placeholder\",\"year\":2021,\"catalogs\":{\"4383bd62-e829-491e-8bb5-b40bd649817f\":{\"id\":\"42bcdb35-c6b9-4ff2-bac0-2d2fa575f042\",\"name\":\"Residência (Acesso Direto)\"},\"5d401e50-47cf-4d06-9a2f-19997cd0f258\":{\"id\":\"e7b1a3be-f837-4ed3-868d-18768d33b4a3\",\"name\":\"Instituto Brasileiro de Gestão e Pesquisa (IBGP)\"},\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\":{\"id\":\"260b7239-0661-48ec-80cb-161a373e4367\",\"name\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},\"75851bb5-e834-49af-affe-50e954c40801\":{\"id\":\"0609ccdb-db5c-4c47-a306-31a0a655e95c\",\"name\":\"Ginecologia e Obstetrícia\"},\"7930032c-3d1b-4a19-a8c8-12bb8137e59a\":{\"id\":\"27dbfbf8-939d-4abc-b3d8-ea268d974c45\",\"name\":\"3 anos\"},\"8ff170f3-13a5-4421-8474-4e39649c523f\":{\"id\":\"c0fb2a79-d5f3-4686-8eb4-078b329da379\",\"name\":\"Não se aplica\"},\"9f5ce998-c2c4-47ed-81d3-a9042f54cc33\":{\"id\":\"b35c6fce-73ec-4b54-aae8-ad664a219e03\",\"name\":\"Privado\"},\"f99244db-58aa-4669-bb7e-4216d75b733d\":{\"id\":\"af7e85c2-2c30-4a9a-ba79-8caf9d22e744\",\"name\":\"Acesso Direto (R1)\"}},\"number\":1,\"complement\":\"\",\"remuneration\":333043,\"open_spaces\":2,\"candidates_number\":0,\"accepted_candidates_number\":0,\"answers_type\":\"MULTIPLE_CHOICE\",\"active\":true,\"degree_proof\":false,\"questions_number\":50,\"created_at\":\"2020-12-04T13:23:29Z\",\"badges\":[{\"type\":\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\",\"text\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},{\"type\":\"YEAR\",\"text\":\"2021\"},{\"type\":\"4383bd62-e829-491e-8bb5-b40bd649817f\",\"text\":\"Residência (Acesso Direto)\"}]},{\"id\":\"4000002128\",\"scholarity\":\"placeholder\",\"year\":2021,\"catalogs\":{\"4383bd62-e829-491e-8bb5-b40bd649817f\":{\"id\":\"42bcdb35-c6b9-4ff2-bac0-2d2fa575f042\",\"name\":\"Residência (Acesso Direto)\"},\"5d401e50-47cf-4d06-9a2f-19997cd0f258\":{\"id\":\"e7b1a3be-f837-4ed3-868d-18768d33b4a3\",\"name\":\"Instituto Brasileiro de Gestão e Pesquisa (IBGP)\"},\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\":{\"id\":\"260b7239-0661-48ec-80cb-161a373e4367\",\"name\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},\"75851bb5-e834-49af-affe-50e954c40801\":{\"id\":\"dcb47678-bdba-4669-aa0e-01f71e32541b\",\"name\":\"Medicina da Família e Comunidade\"},\"7930032c-3d1b-4a19-a8c8-12bb8137e59a\":{\"id\":\"b9d13d45-c27d-4634-985c-fe9924095039\",\"name\":\"2 anos\"},\"8ff170f3-13a5-4421-8474-4e39649c523f\":{\"id\":\"c0fb2a79-d5f3-4686-8eb4-078b329da379\",\"name\":\"Não se aplica\"},\"9f5ce998-c2c4-47ed-81d3-a9042f54cc33\":{\"id\":\"b35c6fce-73ec-4b54-aae8-ad664a219e03\",\"name\":\"Privado\"},\"f99244db-58aa-4669-bb7e-4216d75b733d\":{\"id\":\"af7e85c2-2c30-4a9a-ba79-8caf9d22e744\",\"name\":\"Acesso Direto (R1)\"}},\"number\":1,\"complement\":\"\",\"remuneration\":333043,\"open_spaces\":3,\"candidates_number\":0,\"accepted_candidates_number\":0,\"answers_type\":\"MULTIPLE_CHOICE\",\"active\":true,\"degree_proof\":false,\"questions_number\":50,\"created_at\":\"2020-12-04T13:23:57Z\",\"badges\":[{\"type\":\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\",\"text\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},{\"type\":\"YEAR\",\"text\":\"2021\"},{\"type\":\"4383bd62-e829-491e-8bb5-b40bd649817f\",\"text\":\"Residência (Acesso Direto)\"}]}],\"topics\":[{\"id\":\"ed443eec-6c44-4827-adca-5182ce3e33dc\",\"name\":\"Pediatria\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":true,\"is_main_classification\":true,\"path\":\"Pediatria\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"ed443eec-6c44-4827-adca-5182ce3e33dc\"],\"has_children\":false,\"nodes\":null},{\"id\":\"e105fcd6-c807-487e-9c7e-ab989e14424b\",\"name\":\"Situações em que há restrições ao aleitamento materno\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":false,\"path\":\"Pediatria[$$]Puericultura [$$]Amamentação/ Aleitamento Materno[$$]Prevenção e manejo dos principais problemas relacionados à amamentação[$$]Situações em que há restrições ao aleitamento materno\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"ed443eec-6c44-4827-adca-5182ce3e33dc\",\"99932fd8-33a1-4c4f-8c98-8baa9027c8ef\",\"362a792a-7399-428f-a42e-df4ff8dc0ae1\",\"26abde98-c063-49e9-93c4-f08064287663\",\"e105fcd6-c807-487e-9c7e-ab989e14424b\"],\"has_children\":false,\"nodes\":null}],\"alternatives\":[{\"id\":\"253e5291-6ef3-473f-aedf-82cdc162ed06\",\"position\":\"0\",\"body\":\"Covid-19.\",\"body_json\":null,\"sanitized_body\":\"Covid-19.\",\"correct\":false,\"created_at\":\"2020-12-04T14:17:35Z\",\"updated_at\":\"2025-09-08T15:41:34Z\",\"topics\":[],\"solution\":{\"_key\":\"29d9bf60-7e2b-403a-a709-46589f6ae40a\",\"complete\":\"Incorreta A, mães com COVID 19 podem amamentar desde que utilizem máscara e mantenham os devidos cuidados de higiene.\",\"complete_json\":null,\"sanitized_complete\":\"Incorreta A, mães com COVID 19 podem amamentar desde que utilizem máscara e mantenham os devidos cuidados de higiene.\",\"complete_attachments\":[{\"type\":\"AUDIO\"}],\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":[{\"type\":\"AUDIO\"}],\"author_id\":\"44cd08bd-64c7-4c60-af22-dc2427744fd8\",\"author_profile\":null,\"created_at\":\"2021-09-21T13:53:00Z\",\"updated_at\":\"2021-09-21T13:53:00Z\"},\"answer_percentage\":1,\"answers\":7},{\"id\":\"c0e73b9d-6736-4209-9ddc-a348abc0516c\",\"position\":\"1\",\"body\":\"Mastite.\",\"body_json\":null,\"sanitized_body\":\"Mastite.\",\"correct\":false,\"created_at\":\"2020-12-04T14:17:35Z\",\"updated_at\":\"2025-11-08T17:51:53Z\",\"topics\":[],\"solution\":{\"_key\":\"367d32de-0fb7-488d-b155-95cafe961e59\",\"complete\":\"Incorreta B, lactantes com mastite devem amamentar, mesmo porque, a manutenção do aleitamento materno faz parte do tratamento da mastite lactacional.\",\"complete_json\":null,\"sanitized_complete\":\"Incorreta B, lactantes com mastite devem amamentar, mesmo porque, a manutenção do aleitamento materno faz parte do tratamento da mastite lactacional.\",\"complete_attachments\":[{\"type\":\"AUDIO\"}],\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":[{\"type\":\"AUDIO\"}],\"author_id\":\"44cd08bd-64c7-4c60-af22-dc2427744fd8\",\"author_profile\":null,\"created_at\":\"2021-09-21T13:53:00Z\",\"updated_at\":\"2021-09-21T13:53:00Z\"},\"answer_percentage\":1,\"answers\":4},{\"id\":\"4872068c-cf11-441e-8cd6-6a0642f991b0\",\"position\":\"2\",\"body\":\"Galactosemia.\",\"body_json\":null,\"sanitized_body\":\"Galactosemia.\",\"correct\":true,\"created_at\":\"2020-12-04T14:17:35Z\",\"updated_at\":\"2026-04-02T14:52:23Z\",\"topics\":[],\"solution\":{\"_key\":\"782fb9d8-e247-4b94-9326-7ce02f6c44bf\",\"complete\":\"Correta C esta é uma contraindicação formal à amamentação. Lactentes com galactosemia não devem receber o aleitamento e fórmulas a base de leite de vaca e devem receber a fórmula de soja.\",\"complete_json\":null,\"sanitized_complete\":\"Correta C esta é uma contraindicação formal à amamentação. Lactentes com galactosemia não devem receber o aleitamento e fórmulas a base de leite de vaca e devem receber a fórmula de soja.\",\"complete_attachments\":[{\"type\":\"AUDIO\"}],\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":[{\"type\":\"AUDIO\"}],\"author_id\":\"44cd08bd-64c7-4c60-af22-dc2427744fd8\",\"author_profile\":null,\"created_at\":\"2021-09-21T13:53:00Z\",\"updated_at\":\"2021-09-21T13:53:00Z\"},\"answer_percentage\":96,\"answers\":618},{\"id\":\"9966f217-6777-412e-8c57-bae756532c05\",\"position\":\"3\",\"body\":\"Epstein Barr.\",\"body_json\":null,\"sanitized_body\":\"Epstein Barr.\",\"correct\":false,\"created_at\":\"2020-12-04T14:17:35Z\",\"updated_at\":\"2026-01-21T06:45:10Z\",\"topics\":[],\"solution\":{\"_key\":\"f78475af-df1d-4a09-a1c0-14a7a75d7fcc\",\"complete\":\"Incorreta D a infecção pelo Epstein Barr não consiste em contraindicação ao aleitamento materno.\",\"complete_json\":null,\"sanitized_complete\":\"Incorreta D a infecção pelo Epstein Barr não consiste em contraindicação ao aleitamento materno.\",\"complete_attachments\":[{\"type\":\"AUDIO\"}],\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":[{\"type\":\"AUDIO\"}],\"author_id\":\"44cd08bd-64c7-4c60-af22-dc2427744fd8\",\"author_profile\":null,\"created_at\":\"2021-09-21T13:53:00Z\",\"updated_at\":\"2021-09-21T13:53:00Z\"},\"answer_percentage\":2,\"answers\":15}],\"answer_type\":\"MULTIPLE_CHOICE\",\"statement\":\"O aleitamento materno exclusivo é a alimentação ideal para todo lactente até o sexto mês, porém existem algumas situações que não se recomenda o aleitamento materno. Lembrando que a suspensão do aleitamento deve ser avaliada caso a caso.\\u003cdiv\\u003e\\u003cbr\\u003e\\u003cdiv\\u003eDentre as \\u003cb\\u003eCONTRAINDICAÇÕES\\u003c/b\\u003e clássicas para o aleitamento materno está a/o:\\u003c/div\\u003e\\u003c/div\\u003e\",\"statement_text\":\"O aleitamento materno exclusivo é a alimentação ideal para todo lactente até o sexto mês, porém existem algumas situações que não se recomenda o aleitamento materno. Lembrando que a suspensão do aleitamento deve ser avaliada caso a caso.Dentre as CONTRAINDICAÇÕES clássicas para o aleitamento materno está a/o:\",\"labels\":[\"FINAL_ANSWER_SHEET\"],\"difficulty_level\":\"MEDIUM\",\"created_at\":\"2020-12-04T14:17:35Z\",\"solution\":{\"_key\":\"0ab71945-a3ec-4385-aae5-241ecde9f96b\",\"complete\":\"Caro(a) Estrategista,\\u003cdiv\\u003ePodemos destacar diversas vantagens do aleitamento materno, tanto para a criança quanto para a mãe.\\u003c/div\\u003e\\u003cdiv\\u003eAlgumas são muito importantes e costumam ser cobradas em provas. São elas:\\u003c/div\\u003e\\u003cdiv\\u003ePara o bebê:\\u003c/div\\u003e\\u003cdiv\\u003e\\u003col\\u003e\\u003cli\\u003eEvita mortes infantis\\u003c/li\\u003e\\u003cli\\u003eEvita diarreia e infecções respiratórias\\u003c/li\\u003e\\u003cli\\u003eDiminui o risco de alergias, hipertensão arterial, dislipidemias e diabetes\\u003c/li\\u003e\\u003cli\\u003eReduz o risco de obesidade na criança\\u003c/li\\u003e\\u003cli\\u003eÉ um alimento completo\\u003c/li\\u003e\\u003cli\\u003eEfeito positivo na inteligência\\u003c/li\\u003e\\u003cli\\u003eMelhor desenvolvimento da cavidade oral\\u003c/li\\u003e\\u003c/ol\\u003e\\u003c/div\\u003e\\u003cdiv\\u003ePara a mãe:\\u003c/div\\u003e\\u003cdiv\\u003e\\u003cul\\u003e\\u003cli\\u003eProteção contra o câncer de mama, ovários, útero entre outros\\u003c/li\\u003e\\u003cli\\u003eefeito contraceptivo\\u003c/li\\u003e\\u003cli\\u003emenor custo\\u003c/li\\u003e\\u003cli\\u003epromoção do vínculo afetivo mãe-filho\\u003c/li\\u003e\\u003cli\\u003emelhor qualidade de vida\\u003c/li\\u003e\\u003c/ul\\u003e\\u003cdiv\\u003eSão raras as contraindicações ao aleitamento, vamos aprender?\\u003c/div\\u003e\\u003c/div\\u003e\\u003cdiv\\u003e\\u003cul\\u003e\\u003cli\\u003eMães infectadas pelo HIV.\\u003c/li\\u003e\\u003cli\\u003eMães infectadas pelo HTLV1 e HTLV2.\\u003c/li\\u003e\\u003cli\\u003eCriança portadora de galactosemia, doença rara em que ela não pode ingerir leite humano ou qualquer outro que contenha lactose.\\u003c/li\\u003e\\u003cli\\u003eUso de medicamentos incompatíveis com a amamentação. Alguns fármacos são considerados contraindicados absolutos, outros relativos. Alguns que são comumente cobrados em provas são:- antineoplásicos, radiofármacos (pelo menos durante a meia-vida deles), iodo, amiodarona (pode causar hipotireoidismo no bebê),  raros imunossupressores (como a ciclofosfamida), raros antimicrobianos (como linezolida e ganciclovir),   lítio,  ergotaminas.\\u003c/li\\u003e\\u003c/ul\\u003e\\u003c/div\\u003e\\u003cdiv\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\",\"complete_json\":null,\"sanitized_complete\":\"Caro(a) Estrategista,Podemos destacar diversas vantagens do aleitamento materno, tanto para a criança quanto para a mãe.Algumas são muito importantes e costumam ser cobradas em provas. São elas:Para o bebê:Evita mortes infantisEvita diarreia e infecções respiratóriasDiminui o risco de alergias, hipertensão arterial, dislipidemias e diabetesReduz o risco de obesidade na criançaÉ um alimento completoEfeito positivo na inteligênciaMelhor desenvolvimento da cavidade oralPara a mãe:Proteção contra o câncer de mama, ovários, útero entre outrosefeito contraceptivomenor custopromoção do vínculo afetivo mãe-filhomelhor qualidade de vidaSão raras as contraindicações ao aleitamento, vamos aprender?Mães infectadas pelo HIV.Mães infectadas pelo HTLV1 e HTLV2.Criança portadora de galactosemia, doença rara em que ela não pode ingerir leite humano ou qualquer outro que contenha lactose.Uso de medicamentos incompatíveis com a amamentação. Alguns fármacos são considerados contraindicados absolutos, outros relativos. Alguns que são comumente cobrados em provas são:- antineoplásicos, radiofármacos (pelo menos durante a meia-vida deles), iodo, amiodarona (pode causar hipotireoidismo no bebê),  raros imunossupressores (como a ciclofosfamida), raros antimicrobianos (como linezolida e ganciclovir),   lítio,  ergotaminas.\",\"complete_attachments\":[{\"type\":\"AUDIO\"}],\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":[{\"type\":\"AUDIO\"}],\"author_id\":\"44cd08bd-64c7-4c60-af22-dc2427744fd8\",\"author_profile\":{\"id\":\"44cd08bd-64c7-4c60-af22-dc2427744fd8\",\"full_name\":\"Andrea Makssoudian\",\"avatar_url\":\"https://static.accounts.estrategia.com/20dcd23ddad7aa86f35206fb72182822\",\"about_me\":\"Formada em Medicina pela Universidade Federal de São Paulo.\\nResidência Médica no Instituto da Criança do Hospital das Clínicas da Faculdade de Medicina da Universidade de São Paulo\\nComplementação Especializada em Endocrinologia Pediátrica pelo Instituto da Criança do Hospital das Clínicas da Faculdade de Medicina da Universidade de São Paulo.\\nMédica Pediatra Concursada pela Secretaria de Saúde do Estado de São Paulo.\\nPreceptora do Internato em Medicina na área de Pediatria da Faculdade de Medicina do Centro Universitário São Camilo\\nCoordenadora da Equipe de Pediatria do Hospital Geral de Carapicuíba.\\n\\n\\n\\n\\nrqe52349\",\"social_networks\":[{\"social_network_id\":\"28aff5a7-6fad-4468-b404-8c0851a20f62\",\"profile_social_network_url_path\":\"https://www.twitter.com/andreamakssoud1\",\"name\":\"Twitter\",\"icon_url\":\"https://public-storage.bowie.estrategia.io/redes-sociais/icones/twitter.svg\"},{\"social_network_id\":\"8e4cd641-73e7-43b4-8081-b2814ae13273\",\"profile_social_network_url_path\":\"https://www.facebook.com/andrea.makssoudian.739\",\"name\":\"Facebook\",\"icon_url\":\"https://public-storage.bowie.estrategia.io/redes-sociais/icones/facebook.svg\"},{\"social_network_id\":\"9453ea4c-562d-4148-b58c-f7a7f650d82e\",\"profile_social_network_url_path\":\"https://www.instagram.com/dra.andreamakssoud\",\"name\":\"Instagram\",\"icon_url\":\"https://public-storage.bowie.estrategia.io/red