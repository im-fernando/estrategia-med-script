-fe39a25792d8\",\"f14a08f1-8f0d-4a34-bec9-5fefb352809a\"],\"has_children\":false,\"nodes\":null},{\"id\":\"8b1428e5-85c8-4542-854e-3cea55c48693\",\"name\":\"Trauma Uretral\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":false,\"path\":\"Cirurgia[$$]Trauma[$$]Trauma Abdominal e Pélvico[$$]Traumatismo Urológico[$$]Trauma Uretral\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"c6fe89b8-22b4-4413-9648-3e214e0df60b\",\"d129856b-b32d-4646-957c-8d4b4eb18a27\",\"b6bf1ab1-b1f6-415e-8bcd-ca1bdedffbbb\",\"f13d2e6c-8d61-4078-b2e3-fe39a25792d8\",\"8b1428e5-85c8-4542-854e-3cea55c48693\"],\"has_children\":false,\"nodes\":null}],\"alternatives\":[{\"id\":\"312e3b78-3030-4f59-9f91-0f82e8b3809d\",\"position\":\"0\",\"body\":\"A ausência de hematúria exclui uma injúria ao trato geniturinário.\",\"body_json\":null,\"sanitized_body\":\"A ausência de hematúria exclui uma injúria ao trato geniturinário.\",\"correct\":false,\"created_at\":\"2020-12-04T15:00:46Z\",\"updated_at\":\"2026-02-25T10:53:50Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":1,\"answers\":1},{\"id\":\"f7cf540d-def8-4d2b-b641-670b832c0e5c\",\"position\":\"1\",\"body\":\"A uretrografia retrograda é indicada em caso de hematoma escrotal e presença de sangue no meato uretral.\",\"body_json\":null,\"sanitized_body\":\"A uretrografia retrograda é indicada em caso de hematoma escrotal e presença de sangue no meato uretral.\",\"correct\":true,\"created_at\":\"2020-12-04T15:00:46Z\",\"updated_at\":\"2026-04-08T00:27:12Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":96,\"answers\":132},{\"id\":\"a2d600c8-f74c-44d2-9536-2cb863842c7b\",\"position\":\"2\",\"body\":\"A passagem de uma sonda uretral é necessária em todos pacientes com suspeita de lesão do trato geniturinário.\",\"body_json\":null,\"sanitized_body\":\"A passagem de uma sonda uretral é necessária em todos pacientes com suspeita de lesão do trato geniturinário.\",\"correct\":false,\"created_at\":\"2020-12-04T15:00:46Z\",\"updated_at\":\"2023-02-23T00:47:20Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":2,\"answers\":3},{\"id\":\"27d889b0-218b-4e28-b4c7-48c845834c97\",\"position\":\"3\",\"body\":\"A hematúria franca é diagnóstico de lesão de bexiga, mas não de lesões renais e do ureter.\",\"body_json\":null,\"sanitized_body\":\"A hematúria franca é diagnóstico de lesão de bexiga, mas não de lesões renais e do ureter.\",\"correct\":false,\"created_at\":\"2020-12-04T15:00:46Z\",\"updated_at\":\"2025-05-15T16:55:48Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":1,\"answers\":1}],\"answer_type\":\"MULTIPLE_CHOICE\",\"statement\":\"No trauma abdominal algumas vezes suspeitamos de lesão do trato geniturinário.\\u003cdiv\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv\\u003eSobre esses traumas, é \\u003cb\\u003eCORRETO\\u003c/b\\u003e afirmar que:\\u003c/div\\u003e\",\"statement_text\":\"No trauma abdominal algumas vezes suspeitamos de lesão do trato geniturinário.Sobre esses traumas, é CORRETO afirmar que:\",\"labels\":[\"FINAL_ANSWER_SHEET\"],\"created_at\":\"2020-12-04T15:00:46Z\",\"forum_id\":\"a3ad1430-24f7-45da-a631-d868489808a7