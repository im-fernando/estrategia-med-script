:true,\"degree_proof\":false,\"questions_number\":50,\"created_at\":\"2020-12-04T13:23:57Z\",\"badges\":[{\"type\":\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\",\"text\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},{\"type\":\"YEAR\",\"text\":\"2021\"},{\"type\":\"4383bd62-e829-491e-8bb5-b40bd649817f\",\"text\":\"Residência (Acesso Direto)\"}]}],\"topics\":[{\"id\":\"65978c95-3f8d-41fb-ae0d-1dc435830d80\",\"name\":\"Prevalência\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":true,\"path\":\"Pediatria[$$]Endocrinologia pediátrica[$$]Desordens do Desenvolvimento Sexual (DDS)[$$]DDS-46,XX: hiperplasia adrenal congênita[$$]Prevalência\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"ed443eec-6c44-4827-adca-5182ce3e33dc\",\"5447d31d-8bf1-4b26-86a1-851db616ab0e\",\"4407b872-8ae3-48f3-a564-67995cd86935\",\"96fe031a-715b-41c2-9653-57b1dc9b54d0\",\"65978c95-3f8d-41fb-ae0d-1dc435830d80\"],\"has_children\":false,\"nodes\":null},{\"id\":\"77ed3f2a-c24e-457d-b496-b9ae44ea073d\",\"name\":\"Forma Clássica não Perdedora de sal\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":false,\"path\":\"Pediatria[$$]Endocrinologia pediátrica[$$]Desordens do Desenvolvimento Sexual (DDS)[$$]DDS-46,XX: hiperplasia adrenal congênita[$$]Quadro Clínico[$$]Forma Clássica não Perdedora de sal\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"ed443eec-6c44-4827-adca-5182ce3e33dc\",\"5447d31d-8bf1-4b26-86a1-851db616ab0e\",\"4407b872-8ae3-48f3-a564-67995cd86935\",\"96fe031a-715b-41c2-9653-57b1dc9b54d0\",\"d9e183e0-d83d-4947-9727-2d65fe91733d\",\"77ed3f2a-c24e-457d-b496-b9ae44ea073d\"],\"has_children\":false,\"nodes\":null},{\"id\":\"05cce109-1f74-4e5d-aafd-7729d3f78043\",\"name\":\"Forma Não Clássica\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":false,\"path\":\"Pediatria[$$]Endocrinologia pediátrica[$$]Desordens do Desenvolvimento Sexual (DDS)[$$]DDS-46,XX: hiperplasia adrenal congênita[$$]Quadro Clínico[$$]Forma Não Clássica\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"ed443eec-6c44-4827-adca-5182ce3e33dc\",\"5447d31d-8bf1-4b26-86a1-851db616ab0e\",\"4407b872-8ae3-48f3-a564-67995cd86935\",\"96fe031a-715b-41c2-9653-57b1dc9b54d0\",\"d9e183e0-d83d-4947-9727-2d65fe91733d\",\"05cce109-1f74-4e5d-aafd-7729d3f78043\"],\"has_children\":false,\"nodes\":null}],\"alternatives\":[{\"id\":\"118ea6fb-398b-4846-aad3-ecfbbb134cec\",\"position\":\"0\",\"body\":\"A Hiperplasia Congênita da Supra-Renal (HCSR) é transmitida como distúrbio autossômico recessivo. \",\"body_json\":null,\"sanitized_body\":\"A Hiperplasia Congênita da Supra-Renal (HCSR) é transmitida como distúrbio autossômico recessivo. \",\"correct\":false,\"created_at\":\"2020-12-04T23:41:56Z\",\"updated_at\":\"2026-03-25T01:09:14Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":16,\"answers\":11},{\"id\":\"51167e10-2d06-488c-90ce-895b30cde8ed\",\"position\":\"1\",\"body\":\"A incapacidade de sintetizar enzima totalmente funcionante tem efeitos como: a diminuição relativa da produção de cortisol, o aumento dos níveis de ACTH (hormônio adrenocorticotrófico) e, a hiperplasia da zona reticular do córtex suprarrenal. \",\"body_json\":null,\"sanitized_body\":\"A incapacidade de sintetizar enzima totalmente funcionante tem efeitos como: a diminuição relativa da produção de cortisol, o aumento dos níveis de ACTH (hormônio adrenocorticotrófico) e, a hiperplasia da zona reticular do córtex suprarrenal. \",\"correct\":false,\"created_at\":\"2020-12-04T23:41:56Z\",\"updated_at\":\"2026-03-15T00:32:22Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":17,\"answers\":12},{\"id\":\"9696a9ff-17c1-43a8-9356-09c00796d70d\",\"position\":\"2\",\"body\":\"Na HCSR virilizante simples, as pacientes afetadas são diagnosticadas como meninas recém-nascidas virilizadas ou como meninos masculinizados com crescimento rápido aos 3 a 7 anos.\",\"body_json\":null,\"sanitized_body\":\"Na HCSR virilizante simples, as pacientes afetadas são diagnosticadas como meninas recém-nascidas virilizadas ou como meninos masculinizados com crescimento rápido aos 3 a 7 anos.\",\"correct\":false,\"created_at\":\"2020-12-04T23:41:56Z\",\"updated_at\":\"2026-04-02T12:07:41Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":29,\"answers\":20},{\"id\":\"811a5e1c-380c-4522-9440-a13e0df1ed20\",\"position\":\"3\",\"body\":\"O tipo não clássico de HCSR inclui o anteriormente denominado “início tardio e críptico” e tipicamente apresenta-se com leves distúrbios na voz (mais grave), e crescimento do vulgarmente chamado “pomo de Adão”.\",\"body_json\":null,\"sanitized_body\":\"O tipo não clássico de HCSR inclui o anteriormente denominado “início tardio e críptico” e tipicamente apresenta-se com leves distúrbios na voz (mais grave), e crescimento do vulgarmente chamado “pomo de Adão”.\",\"correct\":true,\"created_at\":\"2020-12-04T23:41:56Z\",\"updated_at\":\"2026-03-03T12:32:30Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":38,\"answers\":26}],\"answer_type\":\"MULTIPLE_CHOICE\",\"statement\":\"Em relação aos distúrbios endócrinos, assinale a alternativa \\u003cb\\u003eINCORRETA\\u003c/b\\u003e:\",\"statement_text\":\"Em relação aos distúrbios endócrinos, assinale a alternativa INCORRETA:\",\"labels\":[\"FINAL_ANSWER_SHEET\"],\"created_at\":\"2020-12-04T23:41:56Z\",\"forum_id\":\"d2daed1c-5063-4c53-bd55-6c6ab1a3a076\",\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"status\":{\"value\":\"ANSWER_REQUESTED\"},\"has_video_solution\":false,\"solution_video_url\":\"\",\"unlisted\":false,\"slug\":\"aos-disturbios93f739051\",\"public\":true,\"solution_video_resolutions\":null,\"has_support_text\":false,\"body_support_html\":\"\",\"body_support_json\":null}],\"pagination\":{\"page\":1,\"per_page\":1,\"total\":9},\"token_pagination\":{\"next_page_token\":\"WzIwMjEsIjQwMDAxMzAxMjEiXQ\"}}\n"
          },
