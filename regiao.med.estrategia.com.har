:true,\"degree_proof\":false,\"questions_number\":50,\"created_at\":\"2020-12-04T13:23:57Z\",\"badges\":[{\"type\":\"63b07b3e-c200-4b3d-b9e6-742a096ae26e\",\"text\":\"ES - Hospital Evangélico de Cachoeira de Itapemirim - HECI\"},{\"type\":\"YEAR\",\"text\":\"2021\"},{\"type\":\"4383bd62-e829-491e-8bb5-b40bd649817f\",\"text\":\"Residência (Acesso Direto)\"}]}],\"topics\":[{\"id\":\"5537d85a-1178-4ac7-b047-283ba95796dc\",\"name\":\"Orgãos genitais femininos\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":true,\"path\":\"Ginecologia[$$]Ginecologia básica[$$]Anatomia  do trato genital feminino[$$]Orgãos genitais femininos\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"64259ae7-f7b7-4e23-9586-39dd38afac19\",\"6749489d-b474-4431-b055-12ad8eef888d\",\"72ecaaae-6b8e-409a-8fec-472e3fe6634e\",\"5537d85a-1178-4ac7-b047-283ba95796dc\"],\"has_children\":false,\"nodes\":null},{\"id\":\"f5f8fc97-3c90-4056-9bef-fd5778525490\",\"name\":\"Coleta da colpocitologia oncótica\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":false,\"path\":\"Ginecologia[$$]Oncologia ginecológica[$$]Rastreamento do câncer de colo do útero[$$]Diretrizes para o rastreamento[$$]Coleta da colpocitologia oncótica\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"64259ae7-f7b7-4e23-9586-39dd38afac19\",\"0f5e5430-b174-485e-95fa-1dbc80a271ae\",\"879ac83a-5a04-4c91-a1a2-ee7ed32cae86\",\"84dce706-ffea-4391-972d-097294677535\",\"f5f8fc97-3c90-4056-9bef-fd5778525490\"],\"has_children\":false,\"nodes\":null},{\"id\":\"b79dfba6-9c3e-4fb5-8215-30f8ac9ac6a0\",\"name\":\"Lesão intraepitelial escamosa de baixo grau\",\"created_at\":\"2025-03-14T19:20:33Z\",\"is_master\":false,\"is_main_classification\":false,\"path\":\"Ginecologia[$$]Oncologia ginecológica[$$]Rastreamento do câncer de colo do útero[$$]Diretrizes para o rastreamento[$$]Interpretação e conduta frente as atipias citológicas[$$]Lesão intraepitelial escamosa de baixo grau\",\"path_id\":[\"5d4b4db2-40fe-4a1d-9f59-43640749deb5\",\"64259ae7-f7b7-4e23-9586-39dd38afac19\",\"0f5e5430-b174-485e-95fa-1dbc80a271ae\",\"879ac83a-5a04-4c91-a1a2-ee7ed32cae86\",\"84dce706-ffea-4391-972d-097294677535\",\"1d3b4e39-5b06-4af5-b531-7bc473187b8d\",\"b79dfba6-9c3e-4fb5-8215-30f8ac9ac6a0\"],\"has_children\":false,\"nodes\":null}],\"alternatives\":[{\"id\":\"ded73b8c-8124-4382-a461-bd6c10e5cf39\",\"position\":\"0\",\"body\":\"A Junção Escamo-Colunar (JEC) raramente permanece restrita ao óstio externo do colo, ao contrário, é ponto dinâmico que se altera em resposta à puberdade, gravidez e menopausa.\",\"body_json\":null,\"sanitized_body\":\"A Junção Escamo-Colunar (JEC) raramente permanece restrita ao óstio externo do colo, ao contrário, é ponto dinâmico que se altera em resposta à puberdade, gravidez e menopausa.\",\"correct\":false,\"created_at\":\"2020-12-04T14:16:40Z\",\"updated_at\":\"2026-03-12T22:12:47Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":9,\"answers\":23},{\"id\":\"5e3a2562-801a-4c9d-bc77-0fd634951517\",\"position\":\"1\",\"body\":\"A Neoplasia Intra-Epitelial Cervical (NIC) é mais frequente no lábio posterior que no anterior, e raramente origina-se nos ângulos ou comissuras laterais.\",\"body_json\":null,\"sanitized_body\":\"A Neoplasia Intra-Epitelial Cervical (NIC) é mais frequente no lábio posterior que no anterior, e raramente origina-se nos ângulos ou comissuras laterais.\",\"correct\":true,\"created_at\":\"2020-12-04T14:16:40Z\",\"updated_at\":\"2026-04-07T01:45:35Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":67,\"answers\":166},{\"id\":\"b61b99ef-cedd-4635-ae91-fc3e749cbb5d\",\"position\":\"2\",\"body\":\"Os lactobacilos atuam sobre o glicogênio, presentes nas células da mucosa vaginal, com reflexos no pH, estimulando as células de reserva sub-colunares à metaplasia.\",\"body_json\":null,\"sanitized_body\":\"Os lactobacilos atuam sobre o glicogênio, presentes nas células da mucosa vaginal, com reflexos no pH, estimulando as células de reserva sub-colunares à metaplasia.\",\"correct\":false,\"created_at\":\"2020-12-04T14:16:40Z\",\"updated_at\":\"2026-03-20T14:55:40Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":13,\"answers\":32},{\"id\":\"b6829bd2-6c82-48a0-975b-f015a83c282c\",\"position\":\"3\",\"body\":\"A zona de transformação é o resultado do avanço da metaplasia em direção ao óstio externo e sobre as vilosidades colunares.\",\"body_json\":null,\"sanitized_body\":\"A zona de transformação é o resultado do avanço da metaplasia em direção ao óstio externo e sobre as vilosidades colunares.\",\"correct\":false,\"created_at\":\"2020-12-04T14:16:40Z\",\"updated_at\":\"2026-04-06T17:47:34Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":11,\"answers\":28}],\"answer_type\":\"MULTIPLE_CHOICE\",\"statement\":\"Em relação a doença intra-epitelial do colo, assinale a alternativa\\u003cb\\u003e INCORRETA:\\u003c/b\\u003e\",\"statement_text\":\"Em relação a doença intra-epitelial do colo, assinale a alternativa INCORRETA:\",\"labels\":[\"FINAL_ANSWER_SHEET\"],\"created_at\":\"2020-12-04T14:16:40Z\",\"forum_id\":\"2e0081cf-c393-492f-ad84-15a