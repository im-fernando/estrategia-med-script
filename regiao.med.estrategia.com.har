n\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":1,\"answers\":1},{\"id\":\"e95beed3-d064-4e6c-9c4b-69bb8ffc6c0b\",\"position\":\"1\",\"body\":\"Dengue/iniciar hidratação venosa e encaminhar para unidade hospitalar.\",\"body_json\":null,\"sanitized_body\":\"Dengue/iniciar hidratação venosa e encaminhar para unidade hospitalar.\",\"correct\":true,\"created_at\":\"2020-12-04T15:27:05Z\",\"updated_at\":\"2025-11-08T23:09:45Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":96,\"answers\":85},{\"id\":\"de2f6555-32ed-4d54-85f1-679139f18808\",\"position\":\"2\",\"body\":\"Doença meningocócica/isolar e encaminhar para o centro especializado.\",\"body_json\":null,\"sanitized_body\":\"Doença meningocócica/isolar e encaminhar para o centro especializado.\",\"correct\":false,\"created_at\":\"2020-12-04T15:27:05Z\",\"updated_at\":\"2023-02-23T00:53:49Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":2,\"answers\":2},{\"id\":\"96afa18d-cbee-4707-87df-d996c95a76ab\",\"position\":\"3\",\"body\":\"Leptospirose/iniciar antibioticoterapia.\",\"body_json\":null,\"sanitized_body\":\"Leptospirose/iniciar antibioticoterapia.\",\"correct\":false,\"created_at\":\"2020-12-04T15:27:05Z\",\"updated_at\":\"2023-02-23T00:53:50Z\",\"topics\":[],\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"answer_percentage\":1,\"answers\":1}],\"answer_type\":\"MULTIPLE_CHOICE\",\"statement\":\"H.J.K\\t, 33 anos, sexo masculino, procura a Unidade Básica de Saúde (UBS) devido a quadro de cefaleia intensa, febre persistente, mialgia e náuseas de início há 05 dias, com início hoje de sensação de vertigem e manchas pela pele. Durante avaliação, paciente prostrado, PA: 110X60mmHg com hipotensão postural, dor a palpação abdominal e exantema, sem demais alterações ao exame físico.\\u003cdiv\\u003e\\u003cbr\\u003e\\u003cdiv\\u003eDiante do quadro descrito, assinale a alternativa que apresenta a \\u003cb\\u003eMELHOR\\u003c/b\\u003e hipótese diagnóstica e conduta.\\u003c/div\\u003e\\u003c/div\\u003e\",\"statement_text\":\"H.J.K\\t, 33 anos, sexo masculino, procura a Unidade Básica de Saúde (UBS) devido a quadro de cefaleia intensa, febre persistente, mialgia e náuseas de início há 05 dias, com início hoje de sensação de vertigem e manchas pela pele. Durante avaliação, paciente prostrado, PA: 110X60mmHg com hipotensão postural, dor a palpação abdominal e exantema, sem demais alterações ao exame físico.Diante do quadro descrito, assinale a alternativa que apresenta a MELHOR hipótese diagnóstica e conduta.\",\"labels\":[\"FINAL_ANSWER_SHEET\"],\"created_at\":\"2020-12-04T15:27:05Z\",\"solution\":{\"complete\":\"\",\"complete_json\":null,\"sanitized_complete\":\"\",\"complete_attachments\":null,\"brief\":\"\",\"brief_json\":null,\"sanitized_brief\":\"\",\"brief_attachments\":null,\"author_profile\":null},\"status\":{\"value\":\"CREATED\"},\"has_video_solution\":false,\"solution_video_url\":\"\",\"unlisted\":false,\"slug\":\"H-J-K-33-anos-sexo74d2f85e41\",\"public\":true,\"solution_video_resolutions\":null,\"has_support_text\":false,\"body_support_html\":\"\",\"body_support_json\":null}],\"pagination\":{\"page\":1,\"per_page\":1,\"total\":17},\"token_pagination\":{\"next_page_token\":\"WzIwMjEsIjQwMDAxM